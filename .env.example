# Copy this file to `.env` and fill in your keys. `.env` is gitignored.

# Google Maps geocoding (recommended). Enables the "first Google Maps result"
# geocoder. Requires a Google Cloud project with billing enabled and the
# "Places API (New)" enabled, then an API key.
GOOGLE_MAPS_API_KEY=

# Anthropic API key - enables the LLM agent mode (otherwise the app uses the
# deterministic pipeline). Optional.
ANTHROPIC_API_KEY=

# Optional: override the agent model id.
# SUNLIGHT_AGENT_MODEL=claude-opus-4-8
